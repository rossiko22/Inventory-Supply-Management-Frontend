{
  "extends": ["expo/tsconfig.base", "../tsconfig.base.json"],
  "compilerOptions": {
    "strict": true,
    "types": ["node", "jest"],
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./*"
      ],
      "@erp/api-types": ["../packages/api-types/src"],
      "@erp/i18n": ["../packages/i18n/src"],
      "@erp/domain": ["../packages/domain/src"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ]
}
